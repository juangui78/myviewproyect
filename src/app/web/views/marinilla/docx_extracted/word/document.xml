fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="165E03CF" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>El Texto de Bienvenida (El Umbral Literario)</w:t></w:r></w:p><w:p w14:paraId="2FC4DCDD" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>Este texto debe aparecer en la pantalla de inicio (</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Splash Screen</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> o </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Home</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve">) apenas el usuario abre la </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00107ED7"><w:t>app</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00107ED7"><w:t>. Su tono debe ser inmersivo e invitar a la acción:</w:t></w:r></w:p><w:p w14:paraId="2E59DAC2" w14:textId="153395B4" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Bienvenido a Resonancias de Esparta</w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>: El Atlas vivo de Marinilla</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>.</w:t></w:r></w:p><w:p w14:paraId="482A2176" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>Marinilla no es solo un punto en el mapa; es una partitura viva. Eres habitante de la Esparta colombiana, una tierra declarada Patrimonio Inmaterial de la Nación, donde el espíritu de la libertad se forjó a golpe de tiple, guitarra y resistencia.</w:t></w:r></w:p><w:p w14:paraId="135295AB" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>Hoy, la ciudad sigue vibrando, pero su memoria está fragmentada. Te invitamos a convertirte en un Expedicionario. En tus manos tienes el artefacto para descifrarla. Escucha lo que está ocurriendo hoy en nuestras calles y busca las huellas ocultas de nuestro pasado.</w:t></w:r></w:p><w:p w14:paraId="624486E1" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>¿Por dónde quieres empezar a explorar?</w:t></w:r></w:p><w:p w14:paraId="79F743B2" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>Debajo de este texto, estarían los dos botones principales de tu interfaz:</w:t></w:r></w:p><w:p w14:paraId="1DECFB54" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:pict w14:anchorId="28B96B72"><v:rect id="_x0000_i1037" style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" fillcolor="#a0a0a0" stroked="f"/></w:pict></w:r></w:p><w:p w14:paraId="27727C24" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">2. Botón 1: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:rFonts w:ascii="Segoe UI Emoji" w:hAnsi="Segoe UI Emoji" w:cs="Segoe UI Emoji"/><w:b/><w:bCs/></w:rPr><w:t>💓</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> EL LATIDO (La Agenda Cultural)</w:t></w:r></w:p><w:p w14:paraId="6E113483" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:t>Dado que la web/</w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00107ED7"><w:t>app</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> actual (agendamarinilla.com) ya tiene la estructura de cartelera, los ajustes para el prototipo de Crea Digital no requieren rehacer el código, sino hacer un </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>reskin</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> (cambio de piel) narrativo:</w:t></w:r></w:p><w:p w14:paraId="251871B7" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Ideas de ajustes pequeños para el prototipo:</w:t></w:r></w:p><w:p w14:paraId="35CF3127" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Cambio de </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>copys</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> (textos):</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> En lugar de "Eventos de la semana", usa "El Pulso de esta semana". En vez de "Categorías", usa "Frecuencias" (Música, Teatro, Literatura).</w:t></w:r></w:p><w:p w14:paraId="689D7D6E" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Etiquetas narrativas:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Si en la agenda hay un evento de rock contemporáneo, digamos, un toque de </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">Los </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Eskejes</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve">, ponle un pequeño tag visual que diga: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>"Ecos del presente"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve">. Si es un ensamble de música tradicional, el tag diría </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>"Raíces"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="7CE1E41C" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>El puente hacia la gamificación:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Al final de la descripción de cada evento de la agenda, añade un pequeño bloque que diga: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>"¿Vas a este evento? Abre los ojos. Cerca de aquí hay un fragmento de la memoria oculto"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="00F90FBF" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:pict w14:anchorId="6C5BBC91"><v:rect id="_x0000_i1038" style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" fillcolor="#a0a0a0" stroked="f"/></w:pict></w:r></w:p><w:p w14:paraId="6DDDB261" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">3. Botón 2: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:rFonts w:ascii="Segoe UI Emoji" w:hAnsi="Segoe UI Emoji" w:cs="Segoe UI Emoji"/><w:b/><w:bCs/></w:rPr><w:t>🔎</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> LA LUPA DEL TIEMPO (El Reto </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Gamificado</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>)</w:t></w:r></w:p><w:p w14:paraId="6D112295" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:lastRenderedPageBreak/><w:t xml:space="preserve">Esta es la sección nueva que integra el concepto de la fotogrametría y la memoria. Al hacer clic, el usuario no ve un directorio aburrido, sino </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>"El Reto del Día"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> o </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>"El Rompecabezas del Patrimonio"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="4568905C" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Cómo estructurarlo para el prototipo:</w:t></w:r></w:p><w:p w14:paraId="5776F85B" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>El Vistazo al Reto:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> El usuario ve una silueta en negro (por ejemplo, la forma de una guitarra) y un acertijo que lo lleva al espacio físico: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>"Fui tallada en las montañas, mis cuerdas cantaron antes que la pólvora. Búscame donde descansan los maestros (Casa de la Cultura)"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="0A229A39" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>La Cacería (El código QR):</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> El usuario va al sitio físico, encuentra un pequeño </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:t>sticker</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> o placa de la </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00107ED7"><w:t>app</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> y lo escanea.</w:t></w:r></w:p><w:p w14:paraId="6C83240B" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>El Descubrimiento (El Modelo 3D):</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Al escanear, se desbloquea la pieza. Aquí se abre el visor 3D (</w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>My_view</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve">). El usuario puede rotar y hacer </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00107ED7"><w:t>zoom</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> a la guitarra histórica.</w:t></w:r></w:p><w:p w14:paraId="7E0AA1B2" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>La Reseña Expandida:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Debajo del modelo 3D no solo está la historia del instrumento, sino que puedes conectar la narrativa con el territorio. Por ejemplo, detallar que la madera proviene del cedro negro o el nogal del bosque montano bajo del Oriente antioqueño, integrando la riqueza de la flora local con el patrimonio artesanal.</w:t></w:r></w:p><w:p w14:paraId="78EA127C" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>La Recompensa:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Al terminar de leer, la </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00107ED7"><w:t>app</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> le avisa: </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>"Has recuperado 1/5 fragmentos del alma musical de Marinilla"</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t>. (Incluso, si lo logras a futuro, esto podría darle un cupón de descuento en negocios locales aliados, cerrando el ciclo económico).</w:t></w:r></w:p><w:p w14:paraId="46D423BF" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>¿Por qué esta ruta es ganadora para mañana?</w:t></w:r></w:p><w:p w14:paraId="536C243D" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Cumple la regla </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Transmedia</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> a la perfección:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> Tienes Plataforma Web/App (El Latido) + Interacción en el Espacio Físico (Búsqueda de </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:t>QRs</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t>) + Realidad Aumentada / Visor 3D (La Lupa del Tiempo).</w:t></w:r></w:p><w:p w14:paraId="76B7076E" w14:textId="77777777" w:rsidR="00107ED7" w:rsidRPr="00107ED7" w:rsidRDefault="00107ED7" w:rsidP="00107ED7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00107ED7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Es viable para el prototipo:</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> En el enlace de "Versión preliminar" de la Ficha Técnica, puedes grabar un video de pantalla (</w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>screencast</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve">) mostrando cómo navegas por la agenda actual (El Latido) y luego mostrar un </w:t></w:r><w:r w:rsidRPr="00107ED7"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>mockup</w:t></w:r><w:r w:rsidRPr="00107ED7"><w:t xml:space="preserve"> o prueba de cómo funciona el escaneo y el modelo 3D (La Lupa). No tiene que estar programado al 100% mañana, solo debe ser funcional como prototipo para demostrar la idea.</w:t></w:r></w:p><w:p w14:paraId="47CCD8EB" w14:textId="5846A1C8" w:rsidR="00FA4667" w:rsidRPr="00107ED7" w:rsidRDefault="00FA4667" w:rsidP="00107ED7"/><w:sectPr w:rsidR="00FA4667" w:rsidRPr="00107ED7"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1417" w:right="1701" w:bottom="1417" w:left="1701" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>